  "keyFeatures": [
    "Unified adapter interface for 56+ DeFi protocols",
    "Support for both EVM (0x...) and Solana (base58) addresses",
    "Browser-compatible with automatic CORS proxy handling",
    "Standardized data normalization and validation",
    "Custom points terminology support",
    "Deprecated points tracking",
    "Built-in testing and health check utilities"
  ],
  "publicApiSurface": [
    "AdapterExport - Main adapter interface type",
    "AdapterResult - Return type for adapter execution",
    "runAdapter(adapter, address) - Execute an adapter with validation",
    "detectAddressType(address) - Detect if address is EVM or SVM",
    "maybeWrapCORSProxy(url) - Wrap URLs with CORS proxy",
    "AddressType - Union type 'evm' | 'svm'",
    "LabelledPoints - Type for categorized point values",
    "DetailedData - Type for detailed point breakdowns"
  ]
}
